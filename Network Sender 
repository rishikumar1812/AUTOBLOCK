"""
network_sender.py  —  DL PC
TCP client: sends a stop command to the Main PC listener.
"""

import socket
import json
import logging

logger = logging.getLogger(__name__)

TIMEOUT_SECONDS = 5


def send_stop_signal(ip: str, port: int, dl_name: str) -> bool:
    """
    Send JSON stop command to Main PC.
    Returns True if Main PC acknowledged OK, False on any error.
    """
    payload = json.dumps({"command": "STOP", "dl": dl_name}).encode("utf-8")

    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
            sock.settimeout(TIMEOUT_SECONDS)
            sock.connect((ip, port))
            sock.sendall(payload)

            response_raw = sock.recv(1024)
            response = json.loads(response_raw.decode("utf-8"))

            if response.get("status") == "OK":
                logger.info(f"Main PC acknowledged STOP for {dl_name}")
                return True
            else:
                logger.error(f"Main PC error: {response.get('message', 'Unknown')}")
                return False

    except socket.timeout:
        logger.error(f"Timeout: Main PC {ip}:{port} did not respond in {TIMEOUT_SECONDS}s")
        return False
    except ConnectionRefusedError:
        logger.error(f"Connection refused: Is the listener running on {ip}:{port}?")
        return False
    except Exception as e:
        logger.error(f"Network error sending to {ip}:{port} — {e}")
        return False
