    # ── Card grid ─────────────────────────────────────────
    def _build_grid(self):
        self.grid_outer = tk.Frame(self.root, bg=BG_MAIN)
        self.grid_outer.pack(fill=tk.BOTH, expand=True, padx=16, pady=8)
        self.grid_frame = tk.Frame(self.grid_outer, bg=BG_MAIN)
        self.grid_frame.pack(fill=tk.BOTH, expand=True)
        self.cards = []
        self._rebuild_grid(cols=self._cols_for_width(
            self.root.winfo_width() or 1100
        ))

    def _cols_for_width(self, width: int) -> int:
        """
        Calculate how many columns fit based on window width.
        Cards need at least 200px each to be readable.
          < 600px  → 1 column
          < 800px  → 2 columns
          < 1100px → 3 columns
          >= 1100px→ 4 columns  (default)
        """
        if width < 600:
            return 1
        elif width < 800:
            return 2
        elif width < 1100:
            return 3
        else:
            return 4

    def _font_sizes_for_width(self, width: int) -> dict:
        """
        Scale font sizes with window width so text never overflows.
        """
        if width < 600:
            return {"title": 11, "name": 9, "val": 8, "status": 7,
                    "sub": 7, "conn": 7}
        elif width < 800:
            return {"title": 12, "name": 10, "val": 9, "status": 7,
                    "sub": 7, "conn": 8}
        elif width < 1100:
            return {"title": 13, "name": 10, "val": 9, "status": 8,
                    "sub": 8, "conn": 8}
        else:
            return {"title": 15, "name": 11, "val": 10, "status": 8,
                    "sub": 8, "conn": 9}

    def _rebuild_grid(self, cols: int) -> None:
        """
        Destroy all existing cards and rebuild grid with new column count.
        Preserves last known stat data so cards show correct state.
        """
        # Clear existing cards
        for widget in self.grid_frame.winfo_children():
            widget.destroy()
        self.cards = []

        # Set column weights so cards expand equally
        for c in range(cols):
            self.grid_frame.columnconfigure(c, weight=1)
        # Remove old column configs beyond new count
        for c in range(cols, 8):
            self.grid_frame.columnconfigure(c, weight=0, minsize=0)

        # Rebuild all cards
        count = DL_COUNT()
        for i in range(count):
            row  = i // cols
            col  = i % cols
            card = self._make_card(
                self.grid_frame, row, col, f"DL{i+1:02d}", i
            )
            self.cards.append(card)

        # Also configure row weights so cards fill vertical space
        total_rows = (count + cols - 1) // cols
        for r in range(total_rows):
            self.grid_frame.rowconfigure(r, weight=1)

        self._last_cols = cols

        # Re-apply last known stats immediately so cards aren't blank
        if self._last_stats:
            self._update_ui(self._last_stats)

    # ── Resize handler — debounced 150ms ──────────────────
    def _on_resize(self, event=None):
        # Only react to root window resize, not child widgets
        if event and event.widget is not self.root:
            return
        if self._resize_id:
            self.root.after_cancel(self._resize_id)
        self._resize_id = self.root.after(150, self._apply_resize)

    def _apply_resize(self):
        """Called 150ms after last resize event — stable size."""
        width  = self.root.winfo_width()
        height = self.root.winfo_height()

        # ── Recalculate columns ───────────────────────────
        new_cols = self._cols_for_width(width)
        if new_cols != self._last_cols:
            self._rebuild_grid(new_cols)

        # ── Scale fonts ───────────────────────────────────
        sizes = self._font_sizes_for_width(width)
        self.f_title.config( size=sizes["title"])
        self.f_name.config(  size=sizes["name"])
        self.f_val.config(   size=sizes["val"])
        self.f_status.config(size=sizes["status"])
        self.f_sub.config(   size=sizes["sub"])
        self.f_time.config(  size=sizes["sub"])
        self.f_conn.config(  size=sizes["conn"])

    def _make_card(self, parent, row, col, dl_name, index):
        frame = tk.Frame(parent, bg=BG_CARD, padx=10, pady=8,
                         highlightbackground=COL_BORDER,
                         highlightthickness=1, cursor="hand2")
        frame.grid(row=row, column=col, padx=5, pady=5, sticky="nsew")
        frame.bind("<Button-1>", lambda e, idx=index: self._open_detail(idx))

        top = tk.Frame(frame, bg=BG_CARD)
        top.pack(fill=tk.X)
        top.bind("<Button-1>", lambda e, idx=index: self._open_detail(idx))

        tk.Label(top, text=dl_name, font=self.f_name,
                 bg=BG_CARD, fg=COL_WHITE,
                 cursor="hand2").pack(side=tk.LEFT)

        lbl_status = tk.Label(top, text="RUNNING", font=self.f_status,
                               bg=COL_RUN, fg=BG_MAIN, padx=6, pady=1)
        lbl_status.pack(side=tk.RIGHT)

        tk.Frame(frame, bg=COL_BORDER, height=1).pack(fill=tk.X, pady=4)

        lbl_fail = tk.Label(frame, text="0", font=self.f_name,
                             bg=BG_CARD, fg=COL_RUN, cursor="hand2")
        lbl_fail.pack()
        tk.Label(frame, text="fails this cycle", font=self.f_sub,
                 bg=BG_CARD, fg=COL_MUTED).pack()

        lbl_rate = tk.Label(frame, text="0.00%", font=self.f_val,
                             bg=BG_CARD, fg=COL_TEXT)
        lbl_rate.pack()
        tk.Label(frame, text="fail rate", font=self.f_sub,
                 bg=BG_CARD, fg=COL_MUTED).pack()

        lbl_last = tk.Label(frame, text="last stop: —", font=self.f_sub,
                             bg=BG_CARD, fg=COL_MUTED)
        lbl_last.pack(pady=(4, 0))

        for w in [lbl_fail, lbl_rate, lbl_last]:
            w.bind("<Button-1>",
                   lambda e, idx=index: self._open_detail(idx))

        return {"frame": frame, "status": lbl_status,
                "fail": lbl_fail, "rate": lbl_rate, "last": lbl_last}

    # ── Footer ────────────────────────────────────────────
    def _build_footer(self):
        self.footer_lbl = tk.Label(
            self.root, text=self._footer_text(),
            font=self.f_sub, bg=BG_HEADER, fg=COL_MUTED, pady=4,
        )
        self.footer_lbl.pack(fill=tk.X, side=tk.BOTTOM)

    def _footer_text(self) -> str:
        return (
            f"Log dir: {LOG_DIRECTORY()}   |   "
            f"Refresh: {REFRESH_MS()//1000}s   |   "
            f"Warn ≥{WARN_AT_FAILS()}   |   "
