# =========================================================
# HELLO/ACK handshake — TCP
# Sends {"command": "HELLO"} to Main PC listener.
# Expects {"status": "ACK"} back.
# Returns (state, detail_message)
# =========================================================
def do_handshake() -> tuple:
    ip   = MAIN_PC_IP()
    port = MAIN_PC_PORT()
    try:
        payload = json.dumps({"command": "HELLO", "from": "DL_PC"}).encode("utf-8")
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.settimeout(5)
            s.connect((ip, port))
            s.sendall(payload)
            raw  = s.recv(1024)
            resp = json.loads(raw.decode("utf-8"))
            if resp.get("status") == "ACK":
                return CONN_CONNECTED, f"Connected to {ip}:{port}"
            else:
                return CONN_DISCONNECTED, f"Bad response: {resp}"
    except socket.timeout:
        return CONN_DISCONNECTED, f"Timeout — {ip}:{port} not responding"
    except ConnectionRefusedError:
        return CONN_DISCONNECTED, f"Refused — Main PC listener not running"
    except Exception as e:
        return CONN_DISCONNECTED, str(e)


# =========================================================
# Read stop_count from register JSON
# =========================================================
def get_stop_count_today(dl_name: str) -> int:
    today_str = date.today().strftime("%Y%m%d")
    path = os.path.join(LOG_REGISTER_DIR(), f"{dl_name}_{today_str}.json")
    try:
        if os.path.exists(path):
            with open(path, "r", encoding="utf-8") as f:
                return int(json.load(f).get("stop_count", 0))
    except Exception:
        pass
    return 0


def _last_stop_str(ts) -> str:
    if ts is None:
        return "—"
    try:
        return pd.Timestamp(ts).strftime("%H:%M:%S")
    except Exception:
        return str(ts)


# =========================================================
# Status color helper
# =========================================================
def _status_color(status: str) -> str:
    return {
        "RUNNING": COL_RUN,
        "WARNING": COL_WARN,
        "BLOCKED": COL_BLOCK,
        "STOPPED": COL_STOP,
    }.get(status, COL_STOP)


# =========================================================
# Compute DL stats
# =========================================================
def compute_dl_stats() -> list:
    stats    = []
    dl_files = [[] for _ in range(DL_COUNT())]
    now      = datetime.now()

    if not os.path.isdir(LOG_DIRECTORY()):
        for i in range(DL_COUNT()):
            stats.append(_empty_stat(f"DL{i+1:02d}", "STOPPED"))
        return stats

    for fname in os.listdir(LOG_DIRECTORY()):
        fpath = os.path.join(LOG_DIRECTORY(), fname)
        if not os.path.isfile(fpath):
            continue
        match = re.search(r"DL(\d{2})", fname, re.IGNORECASE)
        if match and is_today(fpath):
            idx = int(match.group(1)) - 1
            if 0 <= idx < DL_COUNT():
                dl_files[idx].append(fpath)

    all_stops = get_all_stop_times()

    for i, files in enumerate(dl_files):
        dl_name     = f"DL{i+1:02d}"
        stops_today = get_stop_count_today(dl_name)
        stop_entry  = all_stops.get(dl_name, {})
        raw_stop    = stop_entry.get("last_stop")
        last_stop_ts = None
        if raw_stop:
            try:
                last_stop_ts = datetime.fromisoformat(raw_stop)
            except Exception:
                pass

        if not files:
            stats.append(_empty_stat(dl_name, "STOPPED",
                                     stops_today, _last_stop_str(last_stop_ts)))
            continue

        combined = pd.DataFrame()
        for fpath in files:
            df = read_latest_file(fpath)
            if df is not None:
                combined = pd.concat([combined, df], ignore_index=True)

        if combined.empty:
            stats.append(_empty_stat(dl_name, "STOPPED",
                                     stops_today, _last_stop_str(last_stop_ts)))
            continue

        combined  = combined.sort_values("Time_stamp").reset_index(drop=True)
        latest_ts = combined["Time_stamp"].max()
        minutes_since = (now - latest_ts.to_pydatetime()).total_seconds() / 60

        if minutes_since >= NO_DATA_MINUTES():
            stats.append({
                "name": dl_name, "total": len(combined),
                "fails": 0, "rate": 0.0, "status": "STOPPED",
                "stops_today": stops_today,
                "last_stop": _last_stop_str(last_stop_ts),
                "last_data": latest_ts.strftime("%H:%M:%S"),
                "minutes_since": int(minutes_since),
            })
            continue

        if last_stop_ts is not None:
            active = combined[combined["Time_stamp"] > pd.Timestamp(last_stop_ts)]
        else:
            active = combined

        if len(active) > MAX_RECORDS():
            active = active.tail(MAX_RECORDS()).reset_index(drop=True)

        total = len(active)
        if total == 0:
            stats.append({
                "name": dl_name, "total": 0,
                "fails": 0, "rate": 0.0,
                "status": "BLOCKED" if last_stop_ts else "RUNNING",
                "stops_today": stops_today,
                "last_stop": _last_stop_str(last_stop_ts),
                "last_data": latest_ts.strftime("%H:%M:%S"),
                "minutes_since": int(minutes_since),
            })
            continue

        fails      = int(active[active["RESULT"].str.upper() == "FAIL"].shape[0])
        pass_count = int(active[active["RESULT"].str.upper() == "PASS"].shape[0])
        rate       = (fails / total * 100) if total > 0 else 0.0

        if last_stop_ts is not None and pass_count == 0:
            status = "BLOCKED"
        elif fails >= BLOCK_AT_FAILS():
            status = "BLOCKED"
        elif fails >= WARN_AT_FAILS():
            status = "WARNING"
        else:
            status = "RUNNING"

        stats.append({
            "name": dl_name, "total": total,
            "fails": fails, "rate": rate, "status": status,
            "stops_today": stops_today,
            "last_stop": _last_stop_str(last_stop_ts),
            "last_data": latest_ts.strftime("%H:%M:%S"),
            "minutes_since": int(minutes_since),
        })

    return stats


def _empty_stat(dl_name, status="STOPPED", stops_today=0, last_stop="—"):
    return {
        "name": dl_name, "total": 0, "fails": 0,
        "rate": 0.0, "status": status,
        "stops_today": stops_today, "last_stop": last_stop,
        "last_data": "—", "minutes_since": 0,
    }


