# =========================================================
# Load config.json
# Looks for config.json in the same folder as this script.
# Falls back to safe defaults if any key is missing.
# =========================================================
_CONFIG_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "config.json")

def _load_config() -> dict:
    defaults = {
        "paths":      {"log_directory": r"C:\logs", "log_register_dir": r"C:\DL_PC\log_register"},
        "network":    {"main_pc_ip": "192.168.1.100", "ping_timeout_sec": 1},
        "monitor":    {"poll_interval_sec": 30, "max_records_window": 60, "dl_count": 20,
                       "stale_after_minutes": 60},
        "thresholds": {"warn_at_fails": 2, "block_at_fails": 3},
        "dashboard":  {"refresh_interval_ms": 10000, "window_width": 1100, "window_height": 680},
    }
    try:
        if os.path.exists(_CONFIG_PATH):
            with open(_CONFIG_PATH, "r", encoding="utf-8") as f:
                data = json.load(f)
            # Deep-merge: defaults fill in any missing keys
            for section, values in defaults.items():
                if section not in data:
                    data[section] = values
                else:
                    for k, v in values.items():
                        data[section].setdefault(k, v)
            return data
    except Exception as e:
        print(f"[config] Failed to load config.json: {e} — using defaults")
    return defaults

def _save_config(cfg: dict) -> None:
    try:
        with open(_CONFIG_PATH, "w", encoding="utf-8") as f:
            json.dump(cfg, f, indent=4)
    except Exception as e:
        print(f"[config] Failed to save config.json: {e}")

# Initial load
CFG = _load_config()

