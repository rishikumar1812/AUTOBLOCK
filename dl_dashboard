# =========================================================
# Ping helper — works on Windows and Linux
# =========================================================
def ping_host(ip: str, timeout: int = 1) -> bool:
    """Returns True if host is reachable."""
    try:
        system = platform.system().lower()
        if system == "windows":
            cmd = ["ping", "-n", "1", "-w", str(timeout * 1000), ip]
        else:
            cmd = ["ping", "-c", "1", "-W", str(timeout), ip]
        result = subprocess.run(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=timeout + 2,
        )
        return result.returncode == 0
    except Exception:
        return False


# =========================================================
# Read stop_count from JSON that register_logger.py wrote
# =========================================================
def get_stop_count_today(dl_name: str) -> int:
    today_str = date.today().strftime("%Y%m%d")
    path = os.path.join(LOG_REGISTER_DIR(), f"{dl_name}_{today_str}.json")
    try:
        if os.path.exists(path):
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            return int(data.get("stop_count", 0))
    except Exception:
        pass
    return 0


def get_last_stop_str(dl_name: str) -> str:
    """Human-readable last stop time, or '—' if never stopped."""
    ts = get_last_stop_time(dl_name)
    if ts is None:
        return "—"
    try:
        return pd.Timestamp(ts).strftime("%H:%M:%S")
    except Exception:
        return str(ts)


# =========================================================
# Staleness helper
# Returns (is_stale: bool, age_minutes: float | None)
# =========================================================
def _check_stale(df: pd.DataFrame) -> tuple:
    """
    Given a DataFrame with a 'Time_stamp' column, check whether
    the most recent record is older than STALE_AFTER_MINUTES().

    Returns (True, age_minutes) if stale, (False, age_minutes) otherwise.
    Returns (False, None) if the DataFrame is empty.
    """
    if df is None or df.empty:
        return False, None
    try:
        last_ts     = pd.Timestamp(df["Time_stamp"].max())
        now         = pd.Timestamp.now()
        age_minutes = (now - last_ts).total_seconds() / 60.0
        return age_minutes > STALE_AFTER_MINUTES(), age_minutes
    except Exception:
        return False, None


# =========================================================
# Compute stats for all DLs
# =========================================================
def compute_dl_stats() -> list:
    dl_files = [[] for _ in range(DL_COUNT())]
    stats    = []

    if not os.path.isdir(LOG_DIRECTORY()):
        for i in range(DL_COUNT()):
            stats.append({
                "name": f"DL{i+1:02d}", "total": 0, "fails": 0,
                "rate": 0.0, "status": "NO DIR",
                "stops_today": 0, "last_stop": "—",
                "age_minutes": None,
            })
        return stats

    for fname in os.listdir(LOG_DIRECTORY()):
        fpath = os.path.join(LOG_DIRECTORY(), fname)
        if not os.path.isfile(fpath):
            continue
        match = re.search(r"DL(\d{2})", fname, re.IGNORECASE)
        if match and is_today(fpath):
            idx = int(match.group(1)) - 1
            if 0 <= idx < DL_COUNT():
                dl_files[idx].append(fpath)

    for i, files in enumerate(dl_files):
        dl_name     = f"DL{i+1:02d}"
        stops_today = get_stop_count_today(dl_name)
        last_stop   = get_last_stop_str(dl_name)

        if not files:
            stats.append({
                "name": dl_name, "total": 0, "fails": 0,
                "rate": 0.0, "status": "NO FILE",
                "stops_today": stops_today, "last_stop": last_stop,
                "age_minutes": None,
            })
            continue

        combined = pd.DataFrame()
        for fpath in files:
            df = read_latest_file(fpath)
            if df is not None:
                combined = pd.concat([combined, df], ignore_index=True)

        if combined.empty:
            stats.append({
                "name": dl_name, "total": 0, "fails": 0,
                "rate": 0.0, "status": "EMPTY",
                "stops_today": stops_today, "last_stop": last_stop,
                "age_minutes": None,
            })
            continue

        combined = combined.sort_values("Time_stamp").reset_index(drop=True)

        # Filter first, then tail — prevents new records being dropped
        raw_stop = get_last_stop_time(dl_name)
        if raw_stop is not None:
            active = combined[combined["Time_stamp"] > pd.Timestamp(raw_stop)]
        else:
            active = combined

        if len(active) > MAX_RECORDS():
            active = active.tail(MAX_RECORDS()).reset_index(drop=True)

        total = len(active)
        fails = int(active[active["RESULT"].str.upper() == "FAIL"].shape[0]) if total > 0 else 0
        rate  = (fails / total * 100) if total > 0 else 0.0

        # ── Status determination ──────────────────────────
        if fails >= BLOCK_AT_FAILS():
            status = "BLOCKED"
        elif fails >= WARN_AT_FAILS():
            status = "WARNING"
        else:
            status = "OK"

        # ── Staleness check: overrides OK/WARNING/BLOCKED ──
        # Check the active window first; fall back to full combined data
        # so a DL that has been stopped for >60 min is also caught.
        stale_src = active if not active.empty else combined
        is_stale, age_minutes = _check_stale(stale_src)
        if is_stale:
            status = "STALE"

        stats.append({
            "name": dl_name, "total": total, "fails": fails,
            "rate": rate, "status": status,
            "stops_today": stops_today, "last_stop": last_stop,
            "age_minutes": age_minutes,
        })

    return stats


# =========================================================
# Helper: pick status color
# =========================================================
def status_color(status: str) -> str:
    return {
        "BLOCKED": COL_BLOCK,
        "WARNING": COL_WARN,
        "STALE":   COL_STALE,
        "OK":      COL_OK,
    }.get(status, COL_MUTED)


# =========================================================
# Detail Popup — opens when a DL card is clicked
# =========================================================
class DetailPopup(tk.Toplevel):
    def __init__(self, parent, stat: dict):
        super().__init__(parent)
        self.title(f"{stat['name']} — Detail")
        self.configure(bg=BG_POPUP)
        self.resizable(False, False)
        self.grab_set()                         # modal

        f_title  = tkfont.Font(family="Consolas", size=14, weight="bold")
        f_label  = tkfont.Font(family="Consolas", size=10)
        f_value  = tkfont.Font(family="Consolas", size=12, weight="bold")
        f_small  = tkfont.Font(family="Consolas", size=9)

        status = stat["status"]
        color  = status_color(status)

        # ── Title bar ───────────────────────────────────────
        hdr = tk.Frame(self, bg=color, pady=10, padx=20)
        hdr.pack(fill=tk.X)
        tk.Label(hdr, text=stat["name"], font=f_title,
                 bg=color, fg=BG_MAIN).pack(side=tk.LEFT)
        tk.Label(hdr, text=status, font=f_title,
                 bg=color, fg=BG_MAIN).pack(side=tk.RIGHT)

        # ── Stats grid ──────────────────────────────────────
        body = tk.Frame(self, bg=BG_POPUP, padx=24, pady=20)
        body.pack(fill=tk.BOTH, expand=True)

        # Age since last data
        age_str = "—"
        if stat.get("age_minutes") is not None:
            age_min = stat["age_minutes"]
            if age_min < 60:
                age_str = f"{age_min:.1f} min ago"
            else:
                age_str = f"{age_min / 60:.1f} hrs ago"

        rows = [
            ("Fail Count",       str(stat["fails"]),                color),
            ("Fail Rate",        f"{stat['rate']:.2f}%",            COL_TEXT),
            ("Total Records",    str(stat["total"]),                 COL_TEXT),
            ("Last Data",        age_str,
             COL_STALE if status == "STALE" else COL_TEXT),
            ("Last Stop",        stat["last_stop"],                  COL_WARN),
            ("Stops Today",      str(stat["stops_today"]),           COL_TEXT),
            ("Warn Threshold",   f"≥ {WARN_AT_FAILS()} fails",      COL_WARN),
            ("Block Threshold",  f"≥ {BLOCK_AT_FAILS()} fails",     COL_BLOCK),
            ("Stale After",      f"{STALE_AFTER_MINUTES()} min",    COL_STALE),
        ]

        for r, (label, value, val_color) in enumerate(rows):
            tk.Label(body, text=label, font=f_label,
                     bg=BG_POPUP, fg=COL_MUTED,
                     anchor="w", width=18).grid(row=r, column=0, sticky="w", pady=4)
            tk.Label(body, text=value, font=f_value,
                     bg=BG_POPUP, fg=val_color,
                     anchor="w").grid(row=r, column=1, sticky="w", padx=12, pady=4)

        # ── Divider ─────────────────────────────────────────
        tk.Frame(body, bg=COL_BORDER, height=1).grid(
            row=len(rows), column=0, columnspan=2, sticky="ew", pady=10)

        # ── Timestamp ───────────────────────────────────────
        tk.Label(body,
                 text=f"Snapshot at  {datetime.now().strftime('%Y-%m-%d  %H:%M:%S')}",
                 font=f_small, bg=BG_POPUP, fg=COL_MUTED).grid(
                 row=len(rows)+1, column=0, columnspan=2, sticky="w")

        # ── Close button ────────────────────────────────────
        tk.Button(self, text="Close", command=self.destroy,
                  bg=BG_HEADER, fg=COL_TEXT, font=f_label,
                  relief=tk.FLAT, padx=20, pady=8, cursor="hand2",
                  activebackground=COL_BORDER, activeforeground=COL_WHITE
                  ).pack(pady=(0, 16))

        # Centre popup over parent
        self.update_idletasks()
        px = parent.winfo_x() + (parent.winfo_width()  - self.winfo_width())  // 2
        py = parent.winfo_y() + (parent.winfo_height() - self.winfo_height()) // 2
        self.geometry(f"+{px}+{py}")


