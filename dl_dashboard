    # ── Header ────────────────────────────────────────────
    def _build_header(self):
        hdr = tk.Frame(self.root, bg=BG_HEADER, pady=10)
        hdr.pack(fill=tk.X)

        # Left: title
        tk.Label(hdr, text="DL Monitor Dashboard",
                 font=self.f_title, bg=BG_HEADER, fg=COL_WHITE).pack(side=tk.LEFT, padx=20)

        # Right: IP block
        ip_block = tk.Frame(hdr, bg=BG_HEADER)
        ip_block.pack(side=tk.RIGHT, padx=16)

        tk.Label(ip_block, text="MAIN PC", font=self.f_sub,
                 bg=BG_HEADER, fg=COL_MUTED).pack(anchor="e")

        ip_row = tk.Frame(ip_block, bg=BG_HEADER)
        ip_row.pack(anchor="e")

        # Green/red dot
        self.lbl_dot = tk.Label(ip_row, text="●", font=self.f_val,
                                 bg=BG_HEADER, fg=COL_MUTED)
        self.lbl_dot.pack(side=tk.LEFT, padx=(0, 4))

        # IP label — click to edit
        self.lbl_ip = tk.Label(ip_row, text=MAIN_PC_IP(),
                                font=self.f_name, bg=BG_HEADER, fg=COL_ACCT,
                                cursor="hand2")
        self.lbl_ip.pack(side=tk.LEFT)
        self.lbl_ip.bind("<Button-1>", lambda e: self._open_ip_editor())

        # Ping status text
        self.lbl_ping_status = tk.Label(ip_block, text="checking…",
                                         font=self.f_sub, bg=BG_HEADER, fg=COL_MUTED)
        self.lbl_ping_status.pack(anchor="e")

    # ── Summary bar ───────────────────────────────────────
    def _build_summary_bar(self):
        bar = tk.Frame(self.root, bg=BG_CARD, pady=6)
        bar.pack(fill=tk.X, padx=0)

        inner = tk.Frame(bar, bg=BG_CARD)
        inner.pack()

        lbl_cfg = [
            ("OK",      COL_OK),
            ("WARNING", COL_WARN),
            ("BLOCKED", COL_BLOCK),
            ("STALE",   COL_STALE),
        ]
        self._summary_labels = {}
        for key, col in lbl_cfg:
            cell = tk.Frame(inner, bg=BG_CARD, padx=20)
            cell.pack(side=tk.LEFT)
            tk.Label(cell, text=key, font=self.f_sub,
                     bg=BG_CARD, fg=col).pack()
            lbl = tk.Label(cell, text="0", font=self.f_name,
                           bg=BG_CARD, fg=col)
            lbl.pack()
            self._summary_labels[key] = lbl

    # ── Card grid ─────────────────────────────────────────
    def _build_grid(self):
        self._grid_frame = tk.Frame(self.root, bg=BG_MAIN)
        self._grid_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        self._cards = {}   # dl_name → dict of widget refs

    def _render_cards(self, stats: list):
        """Create or update all DL cards."""
        cols = 5

        for i, stat in enumerate(stats):
            name   = stat["name"]
            status = stat["status"]
            col    = status_color(status)
            row_i  = i // cols
            col_i  = i %  cols

            if name not in self._cards:
                # ── Build new card ────────────────────────
                frame = tk.Frame(self._grid_frame, bg=BG_CARD,
                                  relief=tk.FLAT, bd=0,
                                  highlightbackground=COL_BORDER,
                                  highlightthickness=1,
                                  cursor="hand2")
                frame.grid(row=row_i, column=col_i,
                           padx=6, pady=6, sticky="nsew")
                self._grid_frame.grid_columnconfigure(col_i, weight=1)
                self._grid_frame.grid_rowconfigure(row_i, weight=1)

                # Color stripe at top
                stripe = tk.Frame(frame, height=4, bg=col)
                stripe.pack(fill=tk.X)

                # DL name
                lbl_name = tk.Label(frame, text=name, font=self.f_name,
                                     bg=BG_CARD, fg=COL_WHITE)
                lbl_name.pack(pady=(8, 2))

                # Status badge
                lbl_status = tk.Label(frame, text=status, font=self.f_status,
                                       bg=col, fg=BG_MAIN,
                                       padx=6, pady=2)
                lbl_status.pack(pady=(0, 6))

                # Fail count
                lbl_fails = tk.Label(frame,
                                      text=f"Fails: {stat['fails']}",
                                      font=self.f_val, bg=BG_CARD, fg=col)
                lbl_fails.pack()

                # Fail rate
                lbl_rate = tk.Label(frame,
                                     text=f"{stat['rate']:.1f}%",
                                     font=self.f_sub, bg=BG_CARD, fg=COL_MUTED)
                lbl_rate.pack(pady=(0, 2))

                # Last data age line (shown when stale or always)
                lbl_age = tk.Label(frame, text="", font=self.f_sub,
                                    bg=BG_CARD, fg=COL_STALE)
                lbl_age.pack(pady=(0, 2))

                # Stops today
                lbl_stops = tk.Label(frame,
                                      text=f"Stops: {stat['stops_today']}",
                                      font=self.f_sub, bg=BG_CARD, fg=COL_MUTED)
                lbl_stops.pack(pady=(0, 8))

                # Bind click on all children to open detail popup
                for widget in (frame, stripe, lbl_name, lbl_status,
                               lbl_fails, lbl_rate, lbl_age, lbl_stops):
                    widget.bind("<Button-1>",
                                lambda e, s=stat: self._open_detail(s))

                self._cards[name] = {
                    "frame":      frame,
                    "stripe":     stripe,
                    "lbl_status": lbl_status,
                    "lbl_fails":  lbl_fails,
                    "lbl_rate":   lbl_rate,
                    "lbl_age":    lbl_age,
                    "lbl_stops":  lbl_stops,
                    "stat":       stat,
                }

            else:
                # ── Update existing card ──────────────────
                c = self._cards[name]
                c["stat"] = stat

                c["stripe"].configure(bg=col)
                c["lbl_status"].configure(text=status, bg=col)
                c["lbl_fails"].configure(
                    text=f"Fails: {stat['fails']}", fg=col)
                c["lbl_rate"].configure(
                    text=f"{stat['rate']:.1f}%")

                # Re-bind click with fresh stat snapshot
                for widget in (c["frame"], c["stripe"], c["lbl_status"],
                               c["lbl_fails"], c["lbl_rate"],
                               c["lbl_age"], c["lbl_stops"]):
                    widget.bind("<Button-1>",
                                lambda e, s=stat: self._open_detail(s))

            # ── Update "last data" age label ───────────────
            c = self._cards[name]
            age = stat.get("age_minutes")
            if status == "STALE" and age is not None:
                if age < 60:
                    age_txt = f"No data {age:.0f}m ago"
                else:
                    age_txt = f"No data {age/60:.1f}h ago"
                c["lbl_age"].configure(text=age_txt, fg=COL_STALE)
            else:
                c["lbl_age"].configure(text="")

            c["lbl_stops"].configure(
                text=f"Stops: {stat['stops_today']}")

    # ── Footer ────────────────────────────────────────────
    def _build_footer(self):
        footer = tk.Frame(self.root, bg=BG_HEADER, pady=6)
        footer.pack(fill=tk.X, side=tk.BOTTOM)

        # Left: last-refresh timestamp
        self.lbl_refresh = tk.Label(footer, text="", font=self.f_time,
                                     bg=BG_HEADER, fg=COL_MUTED)
        self.lbl_refresh.pack(side=tk.LEFT, padx=16)

        # Right: Threshold editor button
        tk.Button(footer, text="⚙  Thresholds",
                  command=self._open_threshold_editor,
                  bg=BG_CARD, fg=COL_TEXT, font=self.f_sub,
                  relief=tk.FLAT, padx=10, pady=4, cursor="hand2",
                  activebackground=COL_BORDER, activeforeground=COL_WHITE
                  ).pack(side=tk.RIGHT, padx=10)

    # ── Refresh cycle ─────────────────────────────────────
    def refresh(self):
        """Compute fresh stats, update every widget, schedule next refresh."""
        if self._after_id:
            self.root.after_cancel(self._after_id)

        stats = compute_dl_stats()
        self._last_stats = stats
        self._render_cards(stats)
        self._update_summary(stats)
        self._update_footer()
        self._kick_ping()

        self._after_id = self.root.after(REFRESH_INTERVAL_MS(), self.refresh)

    def _update_summary(self, stats: list):
        counts = {"OK": 0, "WARNING": 0, "BLOCKED": 0, "STALE": 0}
        for s in stats:
            key = s["status"]
            if key in counts:
                counts[key] += 1
        for key, lbl in self._summary_labels.items():
            lbl.configure(text=str(counts.get(key, 0)))

    def _update_footer(self):
        ts = datetime.now().strftime("%Y-%m-%d  %H:%M:%S")
        self.lbl_refresh.configure(
            text=f"Last refresh:  {ts}   |   interval: {REFRESH_INTERVAL_MS()//1000}s")

    # ── Ping (runs in background thread) ──────────────────
    def _kick_ping(self):
        def _ping():
            ok = ping_host(MAIN_PC_IP(), PING_TIMEOUT())
            self.root.after(0, self._apply_ping, ok)

        threading.Thread(target=_ping, daemon=True).start()

    def _apply_ping(self, ok: bool):
        self._ping_ok = ok
        self.lbl_dot.configure(fg=COL_OK if ok else COL_BLOCK)
        self.lbl_ip.configure(text=MAIN_PC_IP())
        self.lbl_ping_status.configure(
            text="reachable" if ok else "unreachable",
            fg=COL_OK if ok else COL_BLOCK,
        )

    # ── Popup openers ─────────────────────────────────────
    def _open_detail(self, stat: dict):
        DetailPopup(self.root, stat)

    def _open_threshold_editor(self):
        ThresholdEditor(self.root, on_save_callback=self.refresh)

    def _open_ip_editor(self):
        IPEditor(self.root, on_save_callback=self.refresh)


