import sys
from PyQt6.QtWidgets import (
    QApplication,
    QWidget,
    QLabel,
    QVBoxLayout
)
from PyQt6.QtCore import Qt, QTimer


class DLDashboard(QWidget):

    def __init__(self):

        super().__init__()

        self.setWindowTitle("AutoBlock DL")

        self.setFixedSize(500, 220)

        self.setStyleSheet("""
        QWidget{
            background:#2b2b2b;
            color:white;
        }
        QLabel{
            font-size:16px;
            font-weight:bold;
        }
        """)

        layout = QVBoxLayout()

        self.dl_name = QLabel("DL01")
        self.status = QLabel("STATUS : RUNNING")
        self.fail_count = QLabel("FAIL COUNT : 0 / 3")
        self.fail_rate = QLabel("FAIL RATE : 0.00 %")
        self.last_stop = QLabel("LAST STOP : -")

        self.dl_name.setAlignment(Qt.AlignmentFlag.AlignCenter)

        self.dl_name.setStyleSheet("""
        font-size:26px;
        color:#00C853;
        """)

        layout.addWidget(self.dl_name)
        layout.addWidget(self.status)
        layout.addWidget(self.fail_count)
        layout.addWidget(self.fail_rate)
        layout.addWidget(self.last_stop)

        self.setLayout(layout)

        self.timer = QTimer()
        self.timer.timeout.connect(self.refresh_data)
        self.timer.start(3000)

    def refresh_data(self):

        # Replace with real values
        dl_name = "DL01"
        fail_count = 1
        fail_rate = 5.0
        last_stop = "-"

        self.dl_name.setText(dl_name)

        if fail_count >= 3:
            status = "STOPPED"
            color = "#D50000"
        else:
            status = "RUNNING"
            color = "#00C853"

        self.status.setText(f"STATUS : {status}")
        self.fail_count.setText(f"FAIL COUNT : {fail_count} / 3")
        self.fail_rate.setText(f"FAIL RATE : {fail_rate:.2f} %")
        self.last_stop.setText(f"LAST STOP : {last_stop}")

        self.dl_name.setStyleSheet(f"""
        font-size:26px;
        color:{color};
        """)


app = QApplication(sys.argv)

window = DLDashboard()
window.show()

sys.exit(app.exec())