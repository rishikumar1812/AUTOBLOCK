"""
network_sender.py  —  DL PC
TCP client: sends a stop command to the Main PC listener.

Design:
  - IP and port are passed in at call time (from register_logger.py
    which reads them from config.json) — this file stays stateless.
  - Returns True only on confirmed OK acknowledgement from Main PC.
  - All failure modes logged with specific reason.
"""

import socket
import json
import logging

logger = logging.getLogger(__name__)

TIMEOUT_SECONDS = 5


def send_stop_signal(ip: str, port: int, dl_name: str) -> bool:
    """
    Send JSON stop command to Main PC listener.

    Payload:  {"command": "STOP", "dl": "DL03"}
    Expects:  {"status": "OK"}  from Main PC on success.

    Returns:
        True   — Main PC acknowledged OK
        False  — any network error or non-OK response
    """
    payload = json.dumps({"command": "STOP", "dl": dl_name}).encode("utf-8")

    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
            sock.settimeout(TIMEOUT_SECONDS)
            sock.connect((ip, port))
            sock.sendall(payload)

            response_raw = sock.recv(1024)
            response     = json.loads(response_raw.decode("utf-8"))

            if response.get("status") == "OK":
                logger.info(
                    f"[network_sender] {dl_name} — Main PC {ip}:{port} acknowledged OK"
                )
                return True
            else:
                logger.error(
                    f"[network_sender] {dl_name} — Main PC returned error: "
                    f"{response.get('message', 'unknown')}"
                )
                return False

    except socket.timeout:
        logger.error(
            f"[network_sender] {dl_name} — Timeout: "
            f"Main PC {ip}:{port} did not respond within {TIMEOUT_SECONDS}s"
        )
        return False

    except ConnectionRefusedError:
        logger.error(
            f"[network_sender] {dl_name} — Connection refused: "
            f"Is the listener running on {ip}:{port}?"
        )
        return False

    except json.JSONDecodeError as e:
        logger.error(
            f"[network_sender] {dl_name} — Bad response from Main PC: {e}"
        )
        return False

    except Exception as e:
        logger.error(
            f"[network_sender] {dl_name} — Unexpected error sending to {ip}:{port}: {e}"
        )
        return False
