from PyQt6.QtWidgets import (
    QApplication,
    QMessageBox
)


def show_stop_popup(dl_name):

    app = QApplication.instance()

    if app is None:
        app = QApplication([])

    msg = QMessageBox()

    msg.setWindowTitle(
        "AUTO BLOCK ALERT"
    )

    msg.setIcon(
        QMessageBox.Icon.Warning
    )

    msg.setText(
        f"{dl_name} STOPPED"
    )

    msg.exec()